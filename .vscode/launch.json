{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit: KI-Potenzialanalyse",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "app/streamlit_app.py", "--server.headless", "true"],
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
